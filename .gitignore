# ============================================================
# .gitignore — Projet Django / Gestion Intégrée Multi-Sites
# ============================================================

# --- Variables d'environnement (NE JAMAIS versionner) ---
.env

# --- Caddyfile : désormais versionné (paramétré par {$DOMAIN}/{$ACME_EMAIL} via .env,
#     donc identique sur tous les environnements). Le domaine n'est plus codé en dur. ---

# --- Build du front Angular monté dans Caddy (artefact, pas du code source) ---
front-dist/

# --- Override Docker local (ports dev) — ne pas versionner ---
docker-compose.override.yml

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# --- Environnement virtuel ---
venv/
env/
drf/
.venv/
.env/
.drf/

# --- Django ---
staticfiles/
media/
db.sqlite3
*.sqlite3

# --- Logs ---
*.log
logs/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Tests & coverage ---
.coverage
htmlcov/
.pytest_cache/
coverage.xml

# --- Docker ---
*.env.docker

# --- Divers ---
*.bak
*.tmp
test_permissions_final.py
test_verification.py
